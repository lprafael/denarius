# =============================================================
# Aurelius — Variables de Entorno
# Copie este archivo como ".env" y ajuste los valores.
# =============================================================

# --- Aplicación ---
AURELIUS_APP_NAME=Aurelius

# --- Base de datos ---
# SQLite (desarrollo local):
# AURELIUS_DATABASE_URL=sqlite:///./aurelius_multi.db
# PostgreSQL (producción recomendado):
# 
AURELIUS_DATABASE_URL=postgresql://postgres:admins@localhost:5432/aurelius_db

# --- CORS (separar con coma) ---
AURELIUS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT (¡cambiar en producción por un secreto de al menos 32 caracteres!) ---
AURELIUS_JWT_SECRET=CAMBIAR_EN_PRODUCCION_MUY_LARGO_Y_COMPLEJO_32CHARS
AURELIUS_JWT_ALGORITHM=HS256
AURELIUS_JWT_ACCESS_EXPIRE_MINUTES=60
AURELIUS_JWT_REFRESH_EXPIRE_DAYS=30

# --- QR / SIFEN ---
# URL base para el código QR (test vs producción):
AURELIUS_QR_BASE_URL=https://ekuatia.set.gov.py/consultas/qr
AURELIUS_QR_BASE_URL_TEST=https://ekuatia.set.gov.py/consultas-test/qr

# --- Código de Seguridad del Contribuyente (CSC) ---
# Provisto por la SET al habilitar como facturador electrónico
AURELIUS_ID_CSC_DEFAULT=0001
AURELIUS_CSC_SECRETO=CAMBIAR_EN_PRODUCCION

# --- Ambiente SIFEN: "test" para homologación, "prod" para producción ---
AURELIUS_SIFEN_AMBIENTE=test

# --- URLs Webservices SIFEN (no modificar salvo indicación de SET) ---
AURELIUS_SIFEN_WS_URL_TEST=https://sifen-test.set.gov.py/de/ws/sync/recibe.wsdl
AURELIUS_SIFEN_WS_URL_PROD=https://sifen.set.gov.py/de/ws/sync/recibe.wsdl
AURELIUS_SIFEN_WS_EVENTOS_TEST=https://sifen-test.set.gov.py/de/ws/sync/evento.wsdl
AURELIUS_SIFEN_WS_EVENTOS_PROD=https://sifen.set.gov.py/de/ws/sync/evento.wsdl
AURELIUS_SIFEN_WS_CONSULTA_TEST=https://sifen-test.set.gov.py/de/ws/sync/consulta-de.wsdl
AURELIUS_SIFEN_WS_CONSULTA_PROD=https://sifen.set.gov.py/de/ws/sync/consulta-de.wsdl
AURELIUS_SIFEN_WS_INUTILIZACION_TEST=https://sifen-test.set.gov.py/de/ws/sync/inutiliza.wsdl
AURELIUS_SIFEN_WS_INUTILIZACION_PROD=https://sifen.set.gov.py/de/ws/sync/inutiliza.wsdl

# --- Almacenamiento de certificados .p12 ---
# Directorio en disco donde se guardan los certificados por empresa
AURELIUS_CERT_STORE_PATH=./certs

# --- Validación XSD ---
# Ruta al archivo siRecepDE_v150.xsd (cópielo de la carpeta Manuales/)
AURELIUS_XSD_PATH=./xsd/siRecepDE_v150.xsd
